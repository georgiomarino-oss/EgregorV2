{
  "name": "egregor-v2-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "check:no-screen-hex": "node ./scripts/check-no-hex-in-screens.mjs",
    "ci:design-system": "npm run check:no-screen-hex",
    "lottie:sync": "node ./scripts/sync-lottie-assets.mjs",
    "lottie:sync:check": "node ./scripts/sync-lottie-assets.mjs --check",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/sora": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.1.1",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.2",
    "@react-navigation/native": "^7.1.31",
    "@react-navigation/native-stack": "^7.14.2",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~55.0.4",
    "expo-asset": "~55.0.8",
    "expo-audio": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linear-gradient": "~55.0.8",
    "expo-location": "~55.1.2",
